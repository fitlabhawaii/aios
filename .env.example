# ═══════════════════════════════════════════════════════════════════════════════
# AIOS Starter Kit — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file stores your API keys. It is PRIVATE — never share it or commit it.
#
# HOW THIS WORKS:
# - Each AIOS module you install will tell you which keys it needs
# - Paste your key after the = sign (no quotes needed)
# - Example: OPENAI_API_KEY=sk-abc123...
#
# You don't need ALL of these right away. Start with the ones marked [RECOMMENDED]
# and add others as modules request them.
#
# ═══════════════════════════════════════════════════════════════════════════════


# ─── CORE AI MODELS ──────────────────────────────────────────────────────────
# These power most of what your AIOS does. Get these set up early.

# [RECOMMENDED] Anthropic — Powers Claude Code itself + agent pipelines
# Get yours: https://console.anthropic.com/settings/keys
# Click "Create Key" → copy it (starts with sk-ant-)
# Used by: CommandOS, Daily Brief, agent workers
ANTHROPIC_API_KEY=

# [RECOMMENDED] OpenAI — Whisper transcription, image generation, TTS, embeddings
# Get yours: https://platform.openai.com/api-keys
# Click "Create new secret key" → copy it (starts with sk-)
# Used by: DataOS (transcription), image generation, voice features
OPENAI_API_KEY=

# [RECOMMENDED] Google Gemini — Long-context analysis (1M tokens), image generation
# Get yours: https://aistudio.google.com/apikey
# Click "Create API key" → copy it (starts with AI...)
# Used by: IntelOS (call analysis), Daily Brief, Thumbnail Generator
GEMINI_API_KEY=


# ─── DATA SOURCES ────────────────────────────────────────────────────────────
# Connect your business tools. DataOS walks you through these.

# YouTube Data API — Channel stats, video metrics, subscriber counts
# Get yours: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" first, then create an API key
# Used by: DataOS (YouTube collector)
YOUTUBE_API_KEY=

# Stripe — Revenue, subscriptions, payment data
# Get yours: https://dashboard.stripe.com/apikeys
# Copy the "Secret key" (starts with sk_live_ or sk_test_)
# Used by: DataOS (Stripe collector)
STRIPE_API_KEY=

# Google Analytics (GA4) — Website traffic, conversions, user behavior
# This uses a service account JSON file, not a simple key
# Guide: https://developers.google.com/analytics/devguides/reporting/data/v1/quickstart-client-libraries
# Used by: DataOS (GA4 collector)
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets — Pull data from spreadsheets (P&L, KPIs, etc.)
# Uses the same Google service account as GA4 above
# Used by: DataOS (Sheets collectors)
GOOGLE_SHEETS_CREDENTIALS=

# Bitly — Link click tracking and attribution
# Get yours: https://app.bitly.com/settings/api/
# Click "Generate token"
# Used by: DataOS (Bitly collector)
BITLY_ACCESS_TOKEN=


# ─── COMMUNICATIONS & INTELLIGENCE ──────────────────────────────────────────
# Meeting recordings, Slack messages, mobile access.

# Fireflies.ai — Meeting transcript collection
# Get yours: https://app.fireflies.ai/integrations → API & Webhooks → copy API key
# Used by: IntelOS (meeting collector)
FIREFLIES_API_KEY=

# Slack — Message collection and workspace monitoring
# Create a Slack app: https://api.slack.com/apps → Create New App
# Used by: IntelOS (Slack collector)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Telegram Bot — Mobile command center, notifications, voice capture
# Create a bot: message @BotFather on Telegram → /newbot → copy token
# Used by: CommandOS (Telegram bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ─── RESEARCH & SCRAPING ────────────────────────────────────────────────────
# For content research, competitor analysis, web data.

# Apify — Web scraping (LinkedIn, Reddit, forums, any website)
# Get yours: https://console.apify.com/account/integrations
# Used by: Research commands, content analysis
APIFY_API_TOKEN=

# Supadata — YouTube transcripts, social media data, web scraping
# Get yours: https://supadata.ai/dashboard → API Keys
# Used by: Content Pipeline (transcript fetching), research
SUPADATA_API_KEY=


# ─── CONTENT & PUBLISHING ───────────────────────────────────────────────────
# For content creation and distribution.

# Notion — Content calendar, task management sync
# Create an integration: https://www.notion.so/my-integrations → New integration
# Used by: Content Pipeline (schedule sync)
NOTION_API_KEY=

# Kit (ConvertKit) — Email newsletter broadcasts
# Get yours: https://app.kit.com/account/developer_settings
# Used by: Newsletter automation
KIT_API_KEY=
KIT_API_SECRET=

# HeyGen — AI avatar video generation
# Get yours: https://app.heygen.com/settings → API
# Used by: Course Module Factory
HEYGEN_API_KEY=


# ─── OPTIONAL / ADVANCED ────────────────────────────────────────────────────
# These are useful but not essential to get started.

# ElevenLabs — Text-to-speech (high quality voice generation)
# Get yours: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Deepgram — Speech-to-text (alternative to Whisper)
# Get yours: https://console.deepgram.com/
DEEPGRAM_API_KEY=
